{
  "name": "@pseudo-lab/experibase-sdk",
  "type": "module",
  "version": "0.1.5",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "description": "ExperiBase SDK — feature flag & A/B test client",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "default": "./dist/react.js"
    }
  },
  "typesVersions": {
    "*": {
      "react": [
        "./dist/react.d.ts"
      ]
    }
  },
  "files": ["dist", "src"],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pseudo-Lab/experiment-platform-pseudolab.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/Pseudo-Lab/experiment-platform-pseudolab/issues"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "react": "^18.3.1",
    "typescript": "^5.6.3"
  },
  "keywords": [
    "experibase",
    "feature-flag",
    "ab-test",
    "sdk"
  ],
  "license": "MIT"
}
