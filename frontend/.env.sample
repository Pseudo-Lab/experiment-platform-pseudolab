# --- Frontend (Vite/React) Configuration ---
# All frontend env variables must be prefixed with VITE_
VITE_API_URL=https://sub.pseudolab-devfactory.com/api/v1

# Optional: Direct Supabase access from client (if not using FastAPI as proxy)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# App Settings
VITE_APP_NAME="Data DevGru"
VITE_ENVIRONMENT=development
